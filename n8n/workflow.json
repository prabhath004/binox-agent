{
  "name": "Deep Research Agent — Query Router",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "research",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [220, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "id": "cache-check",
              "leftValue": "={{ $json.body.query }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "exists" }
            }
          ]
        }
      },
      "id": "validate-1",
      "name": "Validate Input",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "jsCode": "const q = items[0].json?.body?.query;\nif (q === undefined || q === null || String(q).trim() === '') {\n  throw new Error('Missing body.query');\n}\nreturn [{ json: { pinned_query: String(q) } }];"
      },
      "id": "pin-query-1",
      "name": "Pin Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/classify",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ query: $json.pinned_query }) }}",
        "options": {}
      },
      "id": "router-1",
      "name": "Classify query (API)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [626, 300]
    },
    {
      "parameters": {
        "jsCode": "const r = items[0].json;\nconst v = String(r.route || '').toLowerCase().trim();\nconst route_label = v === 'research' ? 'research' : 'general';\nconst pin = $('Pin Query').all()[0]?.json?.pinned_query;\nconst pinned_query = pin != null ? String(pin) : '';\nreturn [{ json: { route_label, pinned_query } }];"
      },
      "id": "parse-router-1",
      "name": "Parse Router Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "id": "route-check",
              "leftValue": "={{ $json.route_label }}",
              "rightValue": "research",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "switch-1",
      "name": "Route Decision",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/research",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ query: $json.pinned_query }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "research-1",
      "name": "Research Pipeline (RAG)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1100, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'gpt-4o-mini', messages: [{ role: 'system', content: 'You are a helpful assistant. Answer the user question directly and concisely. This question is outside the scope of our AI developer tooling knowledge base, so answer from your general knowledge.' }, { role: 'user', content: $json.pinned_query }], temperature: 0.3, max_tokens: 1024 }) }}",
        "options": {}
      },
      "id": "general-1",
      "name": "Direct GPT (General)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1100, 420]
    },
    {
      "parameters": {
        "jsCode": "const input = items?.[0]?.json ?? {};\n\n// If this came from the research pipeline, it's already in the desired schema.\nif (typeof input.answer === 'string' && Array.isArray(input.sub_questions) && input.budget_report) {\n  return { json: input };\n}\n\n// Otherwise, treat it as an OpenAI Chat Completions response from Direct GPT.\nconst answer = input.choices?.[0]?.message?.content || input.message?.content || 'No answer';\nreturn {\n  json: {\n    answer,\n    sub_questions: [],\n    sections: [],\n    key_insights: [],\n    limitations: ['Answered from general knowledge - not from research corpus'],\n    sources_used: [],\n    budget_report: { note: 'No research pipeline used - direct GPT response' },\n    memory_state: {},\n    elapsed_seconds: 0\n  }\n};"
      },
      "id": "format-1",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}"
      },
      "id": "respond-1",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1500, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ error: 'Missing query field in request body' }) }}"
      },
      "id": "error-1",
      "name": "Missing Query Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [620, 500]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [{ "node": "Validate Input", "type": "main", "index": 0 }]
      ]
    },
    "Validate Input": {
      "main": [
        [{ "node": "Pin Query", "type": "main", "index": 0 }],
        [{ "node": "Missing Query Error", "type": "main", "index": 0 }]
      ]
    },
    "Pin Query": {
      "main": [
        [{ "node": "Classify query (API)", "type": "main", "index": 0 }]
      ]
    },
